// Cocorico Restaurant Stock Management System
// Database Schema v2.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTHENTICATION & USERS
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?   // Optional for OAuth users
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  restaurants    UserRestaurant[]
  stockMovements StockMovement[]
  sales          Sale[]
  productions    Production[]

  @@index([email])
  @@map("users")
}

enum UserRole {
  ADMIN
  USER
}

// ============================================================================
// RESTAURANTS & MULTI-TENANCY
// ============================================================================

model Restaurant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users              UserRestaurant[]
  products           Product[]
  suppliers          Supplier[]
  bills              Bill[]
  disputes           Dispute[]
  recipeCategories   RecipeCategory[]
  dishFolders        DishFolder[]
  dishes             Dish[]
  menus              Menu[]
  menuSections       MenuSection[]
  sales              Sale[]
  productions        Production[]
  byproducts         Byproduct[]
  byproductSuggestions ByproductSuggestion[]
  dailyMenuConfigs   DailyMenuConfig[]
  dlcs               DLC[]
  priceHistory       PriceHistory[]

  @@index([slug])
  @@map("restaurants")
}

model UserRestaurant {
  id           String   @id @default(cuid())
  userId       String
  restaurantId String
  role         RestaurantRole @default(MEMBER)
  createdAt    DateTime @default(now())

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId])
  @@map("user_restaurants")
}

enum RestaurantRole {
  OWNER
  ADMIN
  MEMBER
}

// ============================================================================
// INVENTORY & PRODUCTS
// ============================================================================

model Product {
  id         String    @id @default(cuid())
  restaurantId String
  name       String    // Full/official name (e.g., "Tomates rondes bio Fournisseur X")
  displayName String?  // Simplified searchable name (e.g., "Tomate")
  aliases    String[]  @default([]) // Alternative names for searching (e.g., ["Tomato", "Tomates"])
  quantity   Float     @default(0)
  unit       Unit      @default(PC)
  unitPrice  Float?
  totalValue Float?

  // Restaurant features
  trackable Boolean   @default(false)
  parLevel  Float?
  category  String?

  // Composite/Prepared product features
  isComposite Boolean @default(false) // If true, this product is made from other products
  yieldQuantity Float? // How much this recipe produces (e.g., 1 L of crème pâtissière)

  // Category organization (for all products)
  categoryId String?
  productCategory RecipeCategory? @relation("ProductCategory", fields: [categoryId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastVerifiedAt DateTime? // Last time this product was verified during inventory sync

  // Relations
  restaurant        Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  movements         StockMovement[]
  billProducts      BillProduct[]
  recipeIngredients RecipeIngredient[]
  disputeProducts   DisputeProduct[]
  dlcs              DLC[]
  byproducts        Byproduct[]
  productions       Production[]      // Productions of this composite product

  // Composite product relations
  compositeIngredients CompositeIngredient[] @relation("CompositeProduct") // Ingredients needed to make this product
  usedInComposites     CompositeIngredient[] @relation("BaseIngredient")   // Composites that use this as ingredient

  // Price history
  priceHistory         PriceHistory[]

  @@index([restaurantId])
  @@index([name])
  @@index([displayName])
  @@index([category])
  @@index([categoryId])
  @@index([isComposite])
  @@map("products")
}

enum Unit {
  // Weight
  KG    // Kilograms
  G     // Grams
  // Volume
  L     // Liters
  ML    // Milliliters
  CL    // Centiliters
  // Count
  PC    // Pieces
  BUNCH // Bunch (e.g., herbs)
  CLOVE // Clove (e.g., garlic)
}

// ============================================================================
// COMPOSITE/PREPARED PRODUCTS
// ============================================================================

model CompositeIngredient {
  id                String @id @default(cuid())
  compositeProductId String // The prepared product (e.g., crème pâtissière)
  baseProductId     String // The ingredient needed (e.g., milk)
  quantity          Float  // Amount needed
  unit              Unit   // Unit of measurement

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  compositeProduct Product @relation("CompositeProduct", fields: [compositeProductId], references: [id], onDelete: Cascade)
  baseProduct      Product @relation("BaseIngredient", fields: [baseProductId], references: [id], onDelete: Restrict)

  @@index([compositeProductId])
  @@index([baseProductId])
  @@map("composite_ingredients")
}

// ============================================================================
// STOCK MOVEMENTS (Event Sourcing)
// ============================================================================

model StockMovement {
  id           String       @id @default(cuid())
  productId    String
  movementType MovementType
  quantity     Float
  balanceAfter Float
  movementDate DateTime     @default(now())

  // References
  billId       String?
  disputeId    String?
  saleId       String?
  productionId String?
  userId       String?

  // Metadata
  reason      String
  description String?
  unitPrice   Float?
  totalValue  Float?
  source      MovementSource @default(MANUAL) // Track if automated or manual
  lossReason  LossReason?    // Reason for stock loss during inventory sync

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  bill       Bill?       @relation(fields: [billId], references: [id])
  dispute    Dispute?    @relation(fields: [disputeId], references: [id])
  sale       Sale?       @relation(fields: [saleId], references: [id])
  production Production? @relation(fields: [productionId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([movementDate])
  @@index([billId])
  @@index([saleId])
  @@index([productionId])
  @@index([source])
  @@map("stock_movements")
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  INITIAL
}

enum MovementSource {
  MANUAL              // Manual entry by user
  SCAN_RECEPTION      // Automated from reception flow (bill scan)
  SCAN_SALES          // Automated from sales flow (receipt scan)
  RECIPE_DEDUCTION    // Automated stock deduction from recipe
  PRODUCTION          // Automated from production/preparation flow
  SYSTEM_ADJUSTMENT   // System-initiated adjustment
}

enum LossReason {
  EXPIRED             // Product expired
  DAMAGED             // Product damaged or broken
  THEFT               // Product stolen
  SPILLAGE            // Product spilled or wasted
  QUALITY_ISSUE       // Quality not acceptable
  MISSING             // Item missing/unaccounted for
  OTHER               // Other reason
}

// ============================================================================
// SUPPLIERS
// ============================================================================

model Supplier {
  id          String   @id @default(cuid())
  restaurantId String
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?  @db.Text
  notes       String?  @db.Text
  isActive    Boolean  @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  bills Bill[]
  dlcs  DLC[]
  priceHistory PriceHistory[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([name])
  @@index([isActive])
  @@map("suppliers")
}

// ============================================================================
// BILLS & DOCUMENTS
// ============================================================================

model Bill {
  id          String     @id @default(cuid())
  restaurantId String
  filename    String
  supplierId  String?
  billDate    DateTime?
  totalAmount Float?
  rawContent  String?    @db.Text
  status      BillStatus @default(PENDING)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  products       BillProduct[]
  disputes       Dispute[]
  stockMovements StockMovement[]
  priceChanges   PriceHistory[]

  @@index([restaurantId])
  @@index([billDate])
  @@index([supplierId])
  @@index([status])
  @@map("bills")
}

enum BillStatus {
  PENDING    // Uploaded but not confirmed
  PROCESSED  // Confirmed and inventory updated
  DISPUTED   // Has active disputes
}

model BillProduct {
  id                  String @id @default(cuid())
  billId              String
  productId           String
  quantityExtracted   Float
  unitPriceExtracted  Float?
  totalValueExtracted Float?

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  bill    Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([billId, productId])
  @@index([billId])
  @@index([productId])
  @@map("bill_products")
}

// ============================================================================
// DISPUTES & RETURNS
// ============================================================================

model Dispute {
  id             String        @id @default(cuid())
  restaurantId   String
  billId         String
  type           DisputeType
  status         DisputeStatus @default(OPEN)
  title          String
  description    String?       @db.Text
  amountDisputed Float?

  // Resolution
  resolvedAt      DateTime?
  resolutionNotes String?   @db.Text

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  bill           Bill              @relation(fields: [billId], references: [id], onDelete: Cascade)
  products       DisputeProduct[]
  stockMovements StockMovement[]

  @@index([restaurantId])
  @@index([billId])
  @@index([status])
  @@map("disputes")
}

enum DisputeType {
  RETURN
  COMPLAINT
  REFUND
}

enum DisputeStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model DisputeProduct {
  id               String @id @default(cuid())
  disputeId        String
  productId        String
  reason           String
  quantityDisputed Float?
  description      String? @db.Text

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([productId])
  @@map("dispute_products")
}

// ============================================================================
// MENU & RECIPES
// ============================================================================

// New hierarchical category system for organizing recipes
model RecipeCategory {
  id        String   @id @default(cuid())
  restaurantId String
  name      String
  icon      String?  // Emoji or icon identifier
  color     String?  // Hex color for visual organization
  order     Int      @default(0) // Display order within same level

  // Hierarchical structure
  parentId  String?
  parent    RecipeCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  RecipeCategory[] @relation("CategoryHierarchy")

  // Category type
  categoryType CategoryType @default(DISH) // DISH or PREPARED_INGREDIENT
  isPredefined Boolean      @default(false) // System-defined vs user-created

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dishes            Dish[]
  products          Product[] @relation("ProductCategory") // For all products (inventory, prepared, etc.)

  @@index([restaurantId])
  @@index([order])
  @@index([parentId])
  @@index([categoryType])
  @@map("recipe_categories")
}

enum CategoryType {
  DISH                // For recipes/dishes
  PREPARED_INGREDIENT // For prepared/composite ingredients
  INVENTORY           // For regular inventory products
}

// Legacy folder system (kept for backward compatibility during migration)
model DishFolder {
  id        String   @id @default(cuid())
  restaurantId String
  name      String
  color     String?  // Optional color for visual organization
  order     Int      @default(0) // Display order
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dishes Dish[]

  @@index([restaurantId])
  @@index([order])
  @@map("dish_folders")
}

model Dish {
  id          String  @id @default(cuid())
  restaurantId String
  name        String
  description String? @db.Text
  isActive    Boolean @default(true)

  // Pricing
  sellingPrice Float? // Price sold to customers

  // Category organization (new)
  categoryId String?
  category   RecipeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Folder organization (legacy - will be removed after migration)
  folderId String?
  folder   DishFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  recipeIngredients RecipeIngredient[]
  sales             Sale[]
  productions       Production[]
  menuDishes        MenuDish[]
  dailyMenuConfigs  DailyMenuConfig[]

  @@index([restaurantId])
  @@index([name])
  @@index([categoryId])
  @@index([folderId])
  @@map("dishes")
}

model RecipeIngredient {
  id               String @id @default(cuid())
  dishId           String
  productId        String
  quantityRequired Float
  unit             String

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  dish    Dish    @relation(fields: [dishId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([dishId])
  @@index([productId])
  @@map("recipe_ingredients")
}

model Menu {
  id          String   @id @default(cuid())
  restaurantId String
  name        String
  description String?  @db.Text
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean  @default(true)

  // Menu type
  menuType    MenuType @default(REGULAR) // REGULAR or DAILY (for "Menu du jour")

  // Pricing
  fixedPrice  Float?      // If set, menu has a fixed price
  pricingType PricingType @default(PRIX_FIXE) // Pricing model
  minCourses  Int?        // For CHOICE menus: minimum courses to select
  maxCourses  Int?        // For CHOICE menus: maximum courses to select

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sections MenuSection[]

  @@index([restaurantId])
  @@index([name])
  @@index([menuType])
  @@map("menus")
}

model MenuSection {
  id           String @id @default(cuid())
  restaurantId String
  menuId       String
  name         String
  displayOrder Int

  // Choice-based menu options
  isRequired Boolean @default(true)  // If false, customer can skip this section
  isOptional Boolean @default(false) // If true, section is optional in choice menus

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menu  Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dishes MenuDish[]

  @@index([restaurantId])
  @@index([menuId])
  @@map("menu_sections")
}

model MenuDish {
  id            String  @id @default(cuid())
  menuSectionId String
  dishId        String
  displayOrder  Int     @default(0)
  notes         String? @db.Text

  // Pricing
  priceOverride Float? // Override dish.sellingPrice for this specific menu

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  section MenuSection @relation(fields: [menuSectionId], references: [id], onDelete: Cascade)
  dish    Dish        @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@index([menuSectionId])
  @@index([dishId])
  @@map("menu_dishes")
}

enum MenuType {
  REGULAR // Standard menu
  DAILY   // Menu du jour - changes daily
}

enum PricingType {
  PRIX_FIXE  // Fixed price for the entire menu (all courses included)
  CHOICE     // Fixed price where customer chooses X courses from Y options
}

// ============================================================================
// SALES TRACKING
// ============================================================================

model Sale {
  id           String   @id @default(cuid())
  restaurantId String
  dishId       String
  quantitySold Int
  saleDate     DateTime @default(now())
  notes        String?  @db.Text
  userId       String?

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dish           Dish            @relation(fields: [dishId], references: [id], onDelete: Restrict)
  user           User?           @relation(fields: [userId], references: [id])
  stockMovements StockMovement[]

  @@index([restaurantId])
  @@index([dishId])
  @@index([saleDate])
  @@index([userId])
  @@map("sales")
}

// ============================================================================
// PRODUCTION TRACKING
// ============================================================================

model Production {
  id               String   @id @default(cuid())
  restaurantId     String
  dishId           String?
  productId        String?  // For composite products (prepared ingredients)
  quantityProduced Float
  productionDate   DateTime @default(now())
  notes            String?  @db.Text
  userId           String?

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dish           Dish?           @relation(fields: [dishId], references: [id], onDelete: Restrict)
  product        Product?        @relation(fields: [productId], references: [id], onDelete: Restrict)
  user           User?           @relation(fields: [userId], references: [id])
  stockMovements StockMovement[]
  byproducts     Byproduct[]

  @@index([restaurantId])
  @@index([dishId])
  @@index([productId])
  @@index([productionDate])
  @@index([userId])
  @@map("productions")
}

// Byproducts generated during production (e.g., vegetable peelings, bones)
model Byproduct {
  id           String        @id @default(cuid())
  restaurantId String
  productionId String
  name         String        // e.g., "Épluchures de carotte"
  quantity     Float
  unit         Unit
  byproductType ByproductType @default(WASTE)

  // Optional: Link to product if the byproduct becomes stock
  productId    String?
  product      Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  notes        String?       @db.Text

  // Timestamps
  createdAt    DateTime      @default(now())

  // Relations
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  production   Production    @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([productionId])
  @@index([byproductType])
  @@map("byproducts")
}

enum ByproductType {
  COMPOST     // Vegetable peelings, organic waste for composting
  STOCK       // Bones, scraps for making stock/broth
  WASTE       // Non-recoverable waste
  REUSE       // Other reusable byproducts
}

// Cache for LLM-generated byproduct suggestions (zero-waste recommendations)
model ByproductSuggestion {
  id               String   @id @default(cuid())
  restaurantId     String
  ingredientsHash  String   @unique // Hash of sorted ingredient IDs for lookup
  ingredientsList  String[] // Array of product IDs for reference
  suggestions      Json     // Array of {name, description, byproductType, usageIdeas}

  // Metadata
  generatedAt      DateTime @default(now())
  usageCount       Int      @default(0) // How many times this was retrieved
  lastUsedAt       DateTime @default(now())

  // Timestamps
  updatedAt        DateTime @updatedAt

  // Relations
  restaurant       Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([ingredientsHash])
  @@index([lastUsedAt])
  @@map("byproduct_suggestions")
}

// ============================================================================
// DAILY MENU CONFIGURATION (Menu du jour)
// ============================================================================

// Daily Menu Configuration (Menu du jour)
// Stores which dish/recipe is configured as menu du jour for a specific date
// Stock is deducted when the menu is sold, not when configured
model DailyMenuConfig {
  id           String   @id @default(cuid())
  restaurantId String
  date         DateTime @db.Date // Date this menu is for
  dishId       String?  // Reference to the dish being used (optional - can be custom)

  // Ingredient configuration for this specific day
  // Can be from the dish recipe or custom ingredients
  ingredients  Json     // Array of {productId, productName, quantityPerServing, unit}

  // Display information
  name         String?  // Optional custom name (defaults to dish name)
  description  String?  @db.Text

  // Timestamps
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dish         Dish?      @relation(fields: [dishId], references: [id], onDelete: SetNull)

  // One menu du jour config per restaurant per day
  @@unique([restaurantId, date])
  @@index([restaurantId])
  @@index([date])
  @@map("daily_menu_configs")
}

// ============================================================================
// DLC (Date Limite de Consommation) TRACKING
// ============================================================================

model DLC {
  id              String   @id @default(cuid())
  restaurantId    String
  productId       String
  expirationDate  DateTime
  quantity        Float
  unit            Unit     @default(PC)
  batchNumber     String?
  supplierId      String?
  status          DLCStatus @default(ACTIVE)

  // OCR metadata
  imageFilename   String?
  ocrRawData      String?  @db.Text

  // Notes
  notes           String?  @db.Text

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([productId])
  @@index([expirationDate])
  @@index([status])
  @@index([supplierId])
  @@map("dlcs")
}

enum DLCStatus {
  ACTIVE      // Product is still consumable
  CONSUMED    // Product has been used
  EXPIRED     // Product has passed expiration date
  DISCARDED   // Product was thrown away
}

// ============================================================================
// PRICE HISTORY & COST TRACKING
// ============================================================================

model PriceHistory {
  id          String   @id @default(cuid())
  restaurantId String
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  oldPrice    Float    // Previous unit price
  newPrice    Float    // New unit price (weighted average after purchase)
  changePercent Float  // Percentage change ((new-old)/old * 100)

  // Purchase details
  quantityPurchased Float? // How many units were purchased at this price
  billId      String?      // Bill that triggered this price change
  bill        Bill?    @relation(fields: [billId], references: [id], onDelete: SetNull)

  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  // Manual price updates
  reason      String?  @db.Text // Why the price changed (e.g., "Seasonal increase", "Promotion")
  changedBy   String?  // User who made the change (for manual updates)

  changedAt   DateTime @default(now())

  // Relations
  restaurant  Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([productId])
  @@index([changedAt])
  @@index([billId])
  @@map("price_history")
}
